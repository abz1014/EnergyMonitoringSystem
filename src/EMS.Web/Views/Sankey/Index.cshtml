@{
    ViewData["Title"] = "Energy Flow (Sankey)";
    var hasData = (bool)(ViewBag.HasData ?? false);
    var range = ViewBag.Range as string ?? "30d";
    var currency = ViewBag.Currency as string ?? "Rs.";
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">
    <div class="mb-4">
        <h1 class="h2 mb-2">Energy Flow Diagram</h1>
        <p class="text-muted">Visualize how total supply distributes across meters and peak/off-peak periods</p>
    </div>

    <form method="get" class="mb-4 p-4" style="background-color: #1E293B; border-radius: 8px;">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label text-light">Time Range</label>
                <select name="range" class="form-select" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;">
                    @foreach (var (val, label) in new[] { ("7d","Last 7 Days"), ("30d","Last 30 Days"), ("90d","Last 90 Days") })
                    {
                        if (range == val) { <option value="@val" selected>@label</option> } else { <option value="@val">@label</option> }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100" style="background-color: #2563EB;">View</button>
            </div>
        </div>
    </form>

    @if (hasData)
    {
        <div style="color: #94A3B8; font-size: 13px; margin-bottom: 16px;">
            Period: @ViewBag.DateRangeLabel | Total Supply: @ViewBag.GrandTotal kWh across @ViewBag.MeterCount meters
        </div>

        <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
            <div id="sankeyChart" style="width: 100%; height: 500px;"></div>
        </div>
    }
    else
    {
        <div class="p-5 text-center" style="background-color: #1E293B; border-radius: 8px;">
            <div style="font-size: 48px; color: #64748B;">&#8651;</div>
            <h4 style="color: #E2E8F0;">No data available for this period</h4>
        </div>
    }
</div>

@if (hasData)
{
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3-sankey@0.12.3/dist/d3-sankey.min.js"></script>
    <script>
        var sankeyData = @Html.Raw(ViewBag.SankeyData);

        var container = document.getElementById('sankeyChart');
        var width = container.clientWidth;
        var height = 500;

        var svg = d3.select('#sankeyChart').append('svg')
            .attr('width', width).attr('height', height)
            .attr('viewBox', [0, 0, width, height]);

        var sankey = d3.sankey()
            .nodeWidth(18)
            .nodePadding(14)
            .extent([[1, 5], [width - 1, height - 5]]);

        var nodeMap = {};
        sankeyData.nodes.forEach(function(n, i) { nodeMap[n.name] = i; });
        var graph = {
            nodes: sankeyData.nodes.map(function(n) { return { name: n.name }; }),
            links: sankeyData.links.map(function(l) { return { source: nodeMap[l.source], target: nodeMap[l.target], value: l.value }; })
        };

        var { nodes, links } = sankey(graph);

        var color = d3.scaleOrdinal(['#2563EB', '#10B981', '#F59E0B', '#8B5CF6', '#EF4444', '#06B6D4', '#EC4899']);

        svg.append('g').selectAll('rect')
            .data(nodes).join('rect')
            .attr('x', function(d) { return d.x0; })
            .attr('y', function(d) { return d.y0; })
            .attr('height', function(d) { return d.y1 - d.y0; })
            .attr('width', function(d) { return d.x1 - d.x0; })
            .attr('fill', function(d, i) { return color(i); });

        svg.append('g').attr('fill', 'none').selectAll('g')
            .data(links).join('path')
            .attr('d', d3.sankeyLinkHorizontal())
            .attr('stroke', function(d) { return color(d.source.index); })
            .attr('stroke-opacity', 0.3)
            .attr('stroke-width', function(d) { return Math.max(1, d.width); })
            .append('title')
            .text(function(d) { return d.source.name + ' → ' + d.target.name + ': ' + d.value.toLocaleString() + ' kWh'; });

        svg.append('g').style('font', '12px sans-serif').style('fill', '#E2E8F0')
            .selectAll('text')
            .data(nodes).join('text')
            .attr('x', function(d) { return d.x0 < width / 2 ? d.x1 + 6 : d.x0 - 6; })
            .attr('y', function(d) { return (d.y1 + d.y0) / 2; })
            .attr('dy', '0.35em')
            .attr('text-anchor', function(d) { return d.x0 < width / 2 ? 'start' : 'end'; })
            .text(function(d) { return d.name; });
    </script>
}
