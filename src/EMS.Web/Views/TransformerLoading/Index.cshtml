@model List<EMS.Web.Controllers.TransformerLoadingController.TransformerStatus>
@{
    ViewData["Title"] = "Transformer Loading";
    var hasData = (bool)(ViewBag.HasData ?? false);
    var hasRatings = (bool)(ViewBag.HasRatings ?? false);
    var range = ViewBag.Range as string ?? "30d";
    var ratings = ViewBag.Ratings as List<EMS.Core.Models.TransformerRating> ?? new();
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">
    <div class="mb-4">
        <h1 class="h2 mb-2">Transformer Loading</h1>
        <p class="text-muted">kVA loading vs nameplate capacity per transformer</p>
    </div>

    <div class="mb-4 p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid #F59E0B;">
        <strong style="color: #F59E0B;">Assumption not yet verified:</strong>
        <span style="color: #E2E8F0;">
            This assumes each meter reads a single transformer's full secondary output (1:1 meter-to-transformer),
            not a sub-feed downstream of it. This has not been confirmed against the actual electrical single-line
            diagram. Nameplate kVA values below are manually entered, not measured — verify them against the
            transformer's physical nameplate.
        </span>
    </div>

    <div class="mb-4 p-4" style="background-color: #1E293B; border-radius: 8px;">
        <h6 class="text-light mb-3">Transformer Nameplate Ratings @(User.IsInRole("Admin") ? "(Admin)" : "(read-only — Admin role required to edit)")</h6>
        <div class="d-none d-md-flex" style="color: #94A3B8; font-size: 11px; text-transform: uppercase; gap: 12px; padding: 4px 0; border-bottom: 1px solid #334155; margin-bottom: 8px;">
            <div style="width: 60px;">Meter</div>
            <div style="width: 160px;">Name</div>
            <div style="width: 120px;">Nameplate kVA</div>
            <div style="width: 120px;">Cooling Class</div>
        </div>
        @if (User.IsInRole("Admin"))
        {
            @foreach (var meterNo in new[] { 1, 2, 3 })
            {
                var r = ratings.FirstOrDefault(x => x.MeterNo == meterNo);
                <form method="post" asp-action="SaveRating" class="d-flex flex-wrap mb-2" style="gap: 12px; align-items: center;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="meterNo" value="@meterNo" />
                    <div style="width: 60px; color: #E2E8F0; font-size: 13px;">@meterNo</div>
                    <input type="text" name="transformerName" value="@(r?.TransformerName ?? $"TX-{meterNo}")" class="form-control form-control-sm" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155; width: 160px;" />
                    <input type="number" name="nameplateKva" value="@(r?.NameplateKva ?? 0)" step="0.1" class="form-control form-control-sm" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155; width: 120px;" />
                    <input type="text" name="coolingClass" value="@(r?.CoolingClass ?? "")" placeholder="e.g. ONAN" class="form-control form-control-sm" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155; width: 120px;" />
                    <button type="submit" class="btn btn-sm btn-outline-light">Save</button>
                </form>
            }
        }
        else
        {
            @foreach (var meterNo in new[] { 1, 2, 3 })
            {
                var r = ratings.FirstOrDefault(x => x.MeterNo == meterNo);
                <div class="d-flex flex-wrap mb-2" style="gap: 12px; align-items: center; font-size: 13px;">
                    <div style="width: 60px; color: #E2E8F0;">@meterNo</div>
                    <div style="width: 160px; color: #E2E8F0;">@(r?.TransformerName ?? $"TX-{meterNo}")</div>
                    <div style="width: 120px; color: #E2E8F0;">@(r?.NameplateKva.ToString() ?? "—") kVA</div>
                    <div style="width: 120px; color: #E2E8F0;">@(r?.CoolingClass ?? "—")</div>
                </div>
            }
        }
    </div>

    @if (hasRatings)
    {
        <form method="get" class="mb-4 p-4" style="background-color: #1E293B; border-radius: 8px;">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label text-light">Time Range</label>
                    <select name="range" class="form-select" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;">
                        @foreach (var (val, label) in new[] { ("7d","Last 7 Days"), ("30d","Last 30 Days"), ("90d","Last 90 Days") })
                        {
                            if (range == val) { <option value="@val" selected>@label</option> } else { <option value="@val">@label</option> }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100" style="background-color: #2563EB;">Analyze</button>
                </div>
            </div>
        </form>

        @if (hasData && Model != null && Model.Count > 0)
        {
            <div style="color: #94A3B8; font-size: 13px; margin-bottom: 16px;">Period: @ViewBag.DateRangeLabel</div>

            <div class="row g-3">
                @foreach (var t in Model)
                {
                    <div class="col-md-4">
                        <a href="/MeterFaceplate?meterId=@t.MeterNo" class="d-block" style="text-decoration: none; transition: transform 0.15s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
                        <div class="p-4" style="background-color: #1E293B; border-radius: 8px; border-top: 4px solid @t.StatusColor;">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div style="color: #FFFFFF; font-size: 16px; font-weight: 600;">@t.TransformerName <span style="color: #2563EB; font-size: 11px; font-weight: 400;">View &rarr;</span></div>
                                    <small style="color: #64748B;">@t.NameplateKva kVA nameplate @(string.IsNullOrEmpty(t.CoolingClass) ? "" : $"({t.CoolingClass})")</small>
                                </div>
                                <span style="color: @t.StatusColor; font-size: 12px; font-weight: 600;">@t.Status</span>
                            </div>
                            <div class="mb-1" style="display:flex; justify-content:space-between; font-size:13px;">
                                <span style="color:#94A3B8;">Peak Loading</span><span style="color:@t.StatusColor;">@t.PeakLoadingPct% (@t.PeakKva kVA)</span>
                            </div>
                            <div style="background: #334155; border-radius: 4px; height: 8px; margin-bottom: 10px;">
                                <div style="background: @t.StatusColor; width: @(Math.Min(t.PeakLoadingPct, 100))%; height: 8px; border-radius: 4px;"></div>
                            </div>
                            <div style="display:flex; justify-content:space-between; font-size:13px;">
                                <span style="color:#94A3B8;">Avg Loading</span><span style="color:#E2E8F0;">@t.AvgLoadingPct% (@t.AvgKva kVA)</span>
                            </div>
                        </div>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-5 text-center" style="background-color: #1E293B; border-radius: 8px;">
                <div style="font-size: 48px; color: #64748B;">&#9889;</div>
                <h4 style="color: #E2E8F0;">No meter data available for this period</h4>
            </div>
        }
    }
    else
    {
        <div class="p-5 text-center" style="background-color: #1E293B; border-radius: 8px;">
            <div style="font-size: 48px; color: #64748B;">&#9881;</div>
            <h4 style="color: #E2E8F0;">Enter nameplate ratings above to see loading analysis</h4>
        </div>
    }
</div>
