@model List<EMS.Core.Interfaces.MeterLiveDto>
@{
    ViewData["Title"] = "Factory Floor Map";
    var hasData = (bool)(ViewBag.HasData ?? false);
    var locations = ViewBag.Locations as Dictionary<int, string> ?? new();
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">
    <div class="mb-4">
        <h1 class="h2 mb-2">Factory Floor Map</h1>
        <p class="text-muted">Click a meter to view live readings. Color indicates status.</p>
    </div>

    @if (hasData)
    {
        <div class="row">
            <div class="col-md-8">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                    <svg id="floorMapSvg" viewBox="0 0 800 500" style="width: 100%; height: auto;">
                        <rect x="10" y="10" width="780" height="480" fill="none" stroke="#334155" stroke-width="2" rx="8" />
                    </svg>
                </div>
            </div>
            <div class="col-md-4">
                <div id="meterDetailPanel" class="p-4" style="background-color: #1E293B; border-radius: 8px; min-height: 300px;">
                    <h5 class="text-light mb-3">Meter Details</h5>
                    <p style="color: #64748B;">Click a meter on the map to view its live readings.</p>
                </div>
                <div class="mt-3 p-3" style="background-color: #1E293B; border-radius: 8px;">
                    <div style="font-size: 12px; color: #94A3B8; margin-bottom: 8px;">Legend</div>
                    <div class="d-flex align-items-center mb-1"><span style="width:12px;height:12px;background:#10B981;border-radius:50%;display:inline-block;margin-right:8px;"></span><span style="font-size:13px;">Online</span></div>
                    <div class="d-flex align-items-center mb-1"><span style="width:12px;height:12px;background:#F59E0B;border-radius:50%;display:inline-block;margin-right:8px;"></span><span style="font-size:13px;">Warning</span></div>
                    <div class="d-flex align-items-center"><span style="width:12px;height:12px;background:#EF4444;border-radius:50%;display:inline-block;margin-right:8px;"></span><span style="font-size:13px;">Offline</span></div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="state-card state-empty">
            <div style="font-size: 48px; color: #64748B;">&#127970;</div>
            <h4 style="color: #E2E8F0;">No meters configured</h4>
        </div>
    }
</div>

@if (hasData)
{
    <script>
        var meters = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(m => new {
            m.MeterId, m.Name, m.Status, kW = m.Power.kW, kVA = m.Power.kVA, m.PowerFactor, m.Frequency,
            v1 = m.Voltage.L1, v2 = m.Voltage.L2, v3 = m.Voltage.L3,
            location = locations.GetValueOrDefault(m.MeterId, "")
        })));

        // Build the floor map entirely client-side (Razor's <text> tag parsing is unreliable for
        // SVG inside loops in this SDK version, so we avoid emitting SVG markup server-side).
        var svgNS = 'http://www.w3.org/2000/svg';
        var svg = document.getElementById('floorMapSvg');

        function resolveFloorIndex(location) {
            if (location.indexOf('1') !== -1) return 0;
            if (location.indexOf('2') !== -1) return 1;
            if (location.indexOf('3') !== -1) return 2;
            return 3;
        }

        function makeEl(tag, attrs, text) {
            var el = document.createElementNS(svgNS, tag);
            for (var k in attrs) { el.setAttribute(k, attrs[k]); }
            if (text !== undefined) { el.textContent = text; }
            return el;
        }

        var floorLabels = ['Floor 1', 'Floor 2', 'Floor 3', 'Unassigned'];
        for (var f = 0; f < 4; f++) {
            var fx = 30 + f * 190;
            svg.appendChild(makeEl('rect', { x: fx, y: 30, width: 190, height: 440, fill: '#0F172A', stroke: '#334155', 'stroke-width': 1, rx: 4 }));
            svg.appendChild(makeEl('text', { x: fx + 95, y: 54, fill: '#94A3B8', 'font-size': 14, 'text-anchor': 'middle', 'font-weight': 600 }, floorLabels[f]));
        }

        var floorSlotCounts = [0, 0, 0, 0];
        meters.forEach(function(m) {
            var floorIndex = resolveFloorIndex(m.location);
            var slot = floorSlotCounts[floorIndex]++;
            var cx = 30 + floorIndex * 190 + 95;
            var cy = 90 + slot * 130;
            var color = m.status === 'online' ? '#10B981' : m.status === 'warning' ? '#F59E0B' : '#EF4444';

            var g = makeEl('g', { class: 'meter-node', style: 'cursor:pointer;' });
            g.addEventListener('click', function() { showMeterDetail(m.meterId); });

            var halo = makeEl('circle', { cx: cx, cy: cy, r: 36, fill: color, 'fill-opacity': 0.15, stroke: color, 'stroke-width': 2 });
            halo.appendChild(makeEl('animate', { attributeName: 'r', values: '36;40;36', dur: '2s', repeatCount: 'indefinite' }));
            g.appendChild(halo);

            g.appendChild(makeEl('circle', { cx: cx, cy: cy, r: 20, fill: color }));
            g.appendChild(makeEl('text', { x: cx, y: cy + 5, fill: '#0F172A', 'font-size': 11, 'text-anchor': 'middle', 'font-weight': 700 }, m.kW.toFixed(0)));
            g.appendChild(makeEl('text', { x: cx, y: cy + 55, fill: '#E2E8F0', 'font-size': 12, 'text-anchor': 'middle' }, m.name));

            svg.appendChild(g);
        });

        function showMeterDetail(id) {
            var m = meters.find(function(x) { return x.meterId === id; });
            if (!m) return;
            var statusColor = m.status === 'online' ? '#10B981' : m.status === 'warning' ? '#F59E0B' : '#EF4444';
            document.getElementById('meterDetailPanel').innerHTML =
                '<h5 class="text-light mb-3">' + m.name + '</h5>' +
                '<div style="color:' + statusColor + '; font-size: 13px; margin-bottom: 16px; text-transform: uppercase; font-weight: 600;">' + m.status + '</div>' +
                '<div class="mb-2" style="display:flex; justify-content:space-between;"><span style="color:#94A3B8;">Active Power</span><span style="color:#E2E8F0;">' + m.kW.toFixed(1) + ' kW</span></div>' +
                '<div class="mb-2" style="display:flex; justify-content:space-between;"><span style="color:#94A3B8;">Apparent Power</span><span style="color:#E2E8F0;">' + m.kVA.toFixed(1) + ' kVA</span></div>' +
                '<div class="mb-2" style="display:flex; justify-content:space-between;"><span style="color:#94A3B8;">Power Factor</span><span style="color:#E2E8F0;">' + m.powerFactor.toFixed(2) + '</span></div>' +
                '<div class="mb-2" style="display:flex; justify-content:space-between;"><span style="color:#94A3B8;">Frequency</span><span style="color:#E2E8F0;">' + m.frequency.toFixed(1) + ' Hz</span></div>' +
                '<div class="mb-2" style="display:flex; justify-content:space-between;"><span style="color:#94A3B8;">Voltage L1/L2/L3</span><span style="color:#E2E8F0;">' + m.v1.toFixed(0) + ' / ' + m.v2.toFixed(0) + ' / ' + m.v3.toFixed(0) + ' V</span></div>' +
                '<a href="/MeterFaceplate?meterId=' + m.meterId + '" class="btn btn-sm btn-primary w-100 mt-3" style="background-color:#2563EB;">View Faceplate</a>';
        }
    </script>
}
