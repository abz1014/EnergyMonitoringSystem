@{
    ViewData["Title"] = "Line-to-Line Voltage Balance";
    var hasData = (bool)(ViewBag.HasData ?? false);
    var range = ViewBag.Range as string ?? "7d";
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">
    <div class="mb-4">
        <h1 class="h2 mb-2">Line-to-Line Voltage Balance</h1>
        <p class="text-muted">Delta-side imbalance (VL1L2/VL2L3/VL1L3) — distinct from the line-to-neutral check on the Voltage Imbalance page</p>
    </div>

    <form method="get" class="mb-4 p-4" style="background-color: #1E293B; border-radius: 8px;">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label text-light">Time Range</label>
                <select name="range" class="form-select" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;">
                    @foreach (var (val, label) in new[] { ("7d","Last 7 Days"), ("30d","Last 30 Days"), ("90d","Last 90 Days") })
                    {
                        if (range == val) { <option value="@val" selected>@label</option> } else { <option value="@val">@label</option> }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100" style="background-color: #2563EB;">Analyze</button>
            </div>
        </div>
    </form>

    @if (hasData)
    {
        var avgImb = (double)ViewBag.AvgImbalance;
        var maxImb = (double)ViewBag.MaxImbalance;
        var avgColor = avgImb > 2 ? "#EF4444" : avgImb > 1 ? "#F59E0B" : "#10B981";
        var maxColor = maxImb > 2 ? "#EF4444" : maxImb > 1 ? "#F59E0B" : "#10B981";

        <div style="color: #94A3B8; font-size: 13px; margin-bottom: 16px;">Period: @ViewBag.DateRangeLabel | @ViewBag.TotalReadings readings | Avg line voltage: @ViewBag.AvgLineVoltage V</div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid @avgColor;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Average Imbalance</div>
                    <div style="color: @avgColor; font-size: 24px; font-weight: 700;">@avgImb%</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid @maxColor;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Peak Imbalance</div>
                    <div style="color: @maxColor; font-size: 24px; font-weight: 700;">@maxImb%</div>
                    <small style="color: #64748B;">at @ViewBag.PeakAt</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid #10B981;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Within NEMA Limit</div>
                    <div style="color: #10B981; font-size: 24px; font-weight: 700;">@ViewBag.PctWithinLimit%</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid #EF4444;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Violations (&gt;2%)</div>
                    <div style="color: #EF4444; font-size: 24px; font-weight: 700;">@ViewBag.ViolationCount</div>
                </div>
            </div>
        </div>

        @if (avgImb > 2)
        {
            <div class="mb-4 p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid #EF4444;">
                <span style="color: #E2E8F0;">
                    Average line-to-line voltage imbalance of <strong style="color:#EF4444;">@avgImb%</strong> exceeds the NEMA MG1 2% threshold.
                    Compare against the line-to-neutral Voltage Imbalance page — if only one of the two shows a problem, it narrows down
                    whether the issue is on the delta side (transformer secondary, line conductors) or the wye/neutral side (single-phase
                    load distribution).
                </span>
            </div>
        }

        <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
            <h5 class="text-light mb-3">Line-to-Line Imbalance Trend</h5>
            <div id="trendChart" style="height: 380px;"></div>
        </div>
    }
    else
    {
        <div class="state-card state-empty">
            <div style="font-size: 48px; color: #64748B;">&#9889;</div>
            <h4 style="color: #E2E8F0;">No line-to-line voltage data available</h4>
            <p style="color: #64748B;">This analysis requires VoltL1L2, VoltL2L3, and VoltL1L3 readings.</p>
        </div>
    }
</div>

@if (hasData)
{
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@latest/dist/apexcharts.min.js"></script>
    <script>
        new ApexCharts(document.querySelector('#trendChart'), {
            series: [{ name: 'Imbalance %', data: @Html.Raw(ViewBag.TrendValues) }],
            chart: { type: 'area', height: 380, background: '#1E293B', toolbar: { show: true }, zoom: { enabled: true } },
            colors: ['#8B5CF6'],
            stroke: { curve: 'smooth', width: 2 },
            fill: { type: 'gradient', gradient: { opacityFrom: 0.4, opacityTo: 0.05 } },
            xaxis: { categories: @Html.Raw(ViewBag.TrendLabels), labels: { style: { colors: '#94A3B8', fontSize: '9px' }, rotate: -45 }, tickAmount: 12 },
            yaxis: { title: { text: 'Imbalance (%)', style: { color: '#94A3B8' } }, labels: { style: { colors: '#94A3B8' }, formatter: function(v) { return v.toFixed(1) + '%'; } } },
            annotations: { yaxis: [{ y: 2, borderColor: '#EF4444', strokeDashArray: 4, label: { text: 'NEMA Limit (2%)', style: { color: '#FFF', background: '#EF4444', fontSize: '11px' } } }] },
            tooltip: { theme: 'dark', y: { formatter: function(v) { return v.toFixed(2) + '%'; } } },
            grid: { borderColor: '#334155' },
            markers: { size: 0, hover: { size: 4 } }
        }).render();
    </script>
}
