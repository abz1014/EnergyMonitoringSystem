@using EMS.Core.Models
@{
    ViewData["Title"] = "Settings";
    var categories = ViewBag.Categories as List<IGrouping<string, AppSetting>> ?? new();
    var success = ViewBag.Success as string;

    var categoryIcons = new Dictionary<string, string>
    {
        { "Tariff", "&#8377;" },
        { "Shifts", "&#9201;" },
        { "General", "&#9881;" }
    };

    var categoryColors = new Dictionary<string, string>
    {
        { "Tariff", "#F59E0B" },
        { "Shifts", "#3B82F6" },
        { "General", "#10B981" }
    };
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">

    <div class="mb-4">
        <h1 class="h2 mb-2">Settings</h1>
        <p class="text-muted">Configure tariff rates, shift schedules, and system parameters. Admin access only.</p>
    </div>

    @if (!string.IsNullOrEmpty(success))
    {
        <div class="mb-4 p-3" style="background-color: #065F46; border-radius: 8px; border-left: 4px solid #10B981;">
            <span style="color: #D1FAE5;">@success</span>
        </div>
    }

    <form method="post" asp-action="Save">
        @Html.AntiForgeryToken()

        @foreach (var category in categories)
        {
            var icon = categoryIcons.GetValueOrDefault(category.Key, "&#9733;");
            var color = categoryColors.GetValueOrDefault(category.Key, "#94A3B8");

            <div class="mb-4 p-4" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid @color;">
                <h4 class="mb-3" style="color: @color;">@Html.Raw(icon) @category.Key</h4>

                <div class="row g-3">
                    @foreach (var setting in category)
                    {
                        var inputType = setting.DataType == "decimal" ? "number" : setting.DataType == "int" ? "number" : "text";
                        var step = setting.DataType == "decimal" ? "0.01" : setting.DataType == "int" ? "1" : "";

                        <div class="col-md-4">
                            <label class="form-label" style="color: #E2E8F0; font-size: 13px; font-weight: 500;">
                                @setting.DisplayName
                            </label>
                            <input type="@inputType"
                                   name="setting_@setting.SettingKey"
                                   value="@setting.SettingValue"
                                   step="@step"
                                   class="form-control"
                                   style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;" />
                            @if (!string.IsNullOrEmpty(setting.Description))
                            {
                                <small style="color: #64748B; font-size: 11px;">@setting.Description</small>
                            }
                            @if (setting.UpdatedAt.HasValue)
                            {
                                <small style="color: #475569; font-size: 10px; display: block;">
                                    Last updated: @setting.UpdatedAt.Value.ToString("MMM dd, yyyy HH:mm") by @(setting.UpdatedBy ?? "system")
                                </small>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary px-5" style="background-color: #2563EB;">Save All Settings</button>
            <a href="/Settings" class="btn btn-outline-secondary">Reset</a>
        </div>

        <div class="mt-3">
            <small style="color: #64748B;">Changes take effect immediately. Cached values refresh within 5 minutes.</small>
        </div>
    </form>
</div>
