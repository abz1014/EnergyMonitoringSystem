@{ ViewData["Title"] = "Reset Password"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0" style="background-color: #1E293B; border-radius: 12px;">
                <div class="card-body p-4">
                    <h1 class="h3 text-center mb-4" style="color: #FFFFFF;">Set New Password</h1>

                    <form method="post" asp-action="ResetPassword">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="token" value="@ViewBag.Token" />
                        <input type="hidden" name="email" value="@ViewBag.Email" />

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <ul class="mb-0">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label" style="color: #E2E8F0;">New Password</label>
                            <input type="password" name="password" class="form-control" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;" placeholder="At least 8 characters" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color: #E2E8F0;">Confirm Password</label>
                            <input type="password" name="confirmPassword" class="form-control" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;" placeholder="Repeat password" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2" style="background-color: #2563EB;">Reset Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
