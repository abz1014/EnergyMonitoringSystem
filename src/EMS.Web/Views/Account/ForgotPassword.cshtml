@{ ViewData["Title"] = "Forgot Password"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0" style="background-color: #1E293B; border-radius: 12px;">
                <div class="card-body p-4">
                    <h1 class="h3 text-center mb-4" style="color: #FFFFFF;">Reset Password</h1>
                    <p class="text-center text-muted mb-4">Enter your email to receive a reset link</p>

                    <form method="post" asp-action="ForgotPassword">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <ul class="mb-0">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label" style="color: #E2E8F0;">Email</label>
                            <input type="email" name="email" class="form-control" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;" placeholder="Enter your email" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2" style="background-color: #2563EB;">Send Reset Link</button>
                    </form>

                    <hr style="border-color: #334155; margin: 20px 0;">
                    <p class="text-center text-muted mb-0">
                        <a asp-action="Login" style="color: #2563EB; text-decoration: none;">Back to Login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
