@{ ViewData["Title"] = "Reset Link Sent"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0" style="background-color: #1E293B; border-radius: 12px;">
                <div class="card-body p-4 text-center">
                    <div style="font-size: 48px; margin-bottom: 16px; color: #10B981;">&#10003;</div>
                    <h2 class="h4 mb-3" style="color: #FFFFFF;">Check Your Email</h2>
                    <p style="color: #94A3B8;">If an account with that email exists, a password reset link has been sent. Please check your inbox.</p>
                    <hr style="border-color: #334155; margin: 20px 0;">
                    <a asp-action="Login" class="btn btn-primary" style="background-color: #2563EB;">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>
