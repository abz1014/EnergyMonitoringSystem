<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Energy Monitoring System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --sidebar-width: 220px;
            --topbar-height: 50px;
            --bg-primary: #0F172A;
            --bg-secondary: #1E293B;
            --bg-tertiary: #334155;
            --text-primary: #E2E8F0;
            --text-secondary: #94A3B8;
            --text-muted: #64748B;
            --accent: #2563EB;
            --border: #334155;
        }

        body { background-color: var(--bg-primary); color: var(--text-primary); margin: 0; overflow-x: hidden; }

        .sidebar {
            position: fixed; top: 0; left: 0; bottom: 0;
            width: var(--sidebar-width);
            background-color: var(--bg-secondary);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            z-index: 1000;
            transition: transform 0.2s;
        }

        .sidebar-brand {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 18px; font-weight: 700;
            color: var(--accent);
            text-decoration: none; display: block;
        }

        .sidebar-nav { flex: 1; padding: 8px 0; overflow-y: auto; }

        .sidebar-search-wrap { padding: 8px 16px 4px; }
        .sidebar-search {
            width: 100%; padding: 7px 10px; font-size: 13px;
            background: var(--bg-primary); color: var(--text-primary);
            border: 1px solid var(--border); border-radius: 6px;
        }
        .sidebar-search::placeholder { color: var(--text-muted); }
        .sidebar-search:focus { outline: none; border-color: var(--accent); }

        .sidebar-group { border-bottom: 1px solid rgba(51,65,85,0.4); }
        .sidebar-group:last-child { border-bottom: none; }
        .sidebar-group-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 9px 20px 9px 16px; cursor: pointer; user-select: none;
            font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;
            color: var(--text-muted); font-weight: 600;
        }
        .sidebar-group-header:hover { color: var(--text-secondary); }
        .sidebar-group-caret { font-size: 10px; transition: transform 0.15s; }
        .sidebar-group.collapsed .sidebar-group-caret { transform: rotate(-90deg); }
        .sidebar-group.collapsed .sidebar-group-links { display: none; }
        .sidebar-group.has-active .sidebar-group-header { color: var(--text-secondary); }

        .sidebar-link {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 20px;
            color: var(--text-secondary);
            text-decoration: none; font-size: 13.5px;
            transition: background-color 0.15s, color 0.15s;
            border-left: 3px solid transparent;
        }
        .sidebar-link:hover { background-color: var(--bg-tertiary); color: var(--text-primary); }
        .sidebar-link.active { color: var(--accent); background-color: rgba(37, 99, 235, 0.1); border-left-color: var(--accent); font-weight: 600; }
        .sidebar-link.hidden-by-search { display: none; }

        .sidebar-icon { width: 18px; text-align: center; font-size: 14px; }

        .sidebar-footer {
            padding: 12px 20px;
            border-top: 1px solid var(--border);
            font-size: 12px;
        }

        .sidebar-user { color: var(--text-secondary); margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        .topbar {
            position: fixed; top: 0; left: var(--sidebar-width); right: 0;
            height: var(--topbar-height);
            background-color: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 24px;
            z-index: 999;
        }

        .topbar-title { font-size: 14px; color: var(--text-primary); font-weight: 500; }
        .topbar-actions { display: flex; align-items: center; gap: 12px; }

        .main-content {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            min-height: calc(100vh - var(--topbar-height));
        }

        .footer {
            margin-left: var(--sidebar-width);
            background-color: var(--bg-secondary);
            border-top: 1px solid var(--border);
            color: var(--text-muted);
        }

        .sidebar-toggle { display: none; background: none; border: none; color: var(--text-primary); font-size: 20px; cursor: pointer; }

        .apexcharts-menu { background: #1E293B !important; border-color: #334155 !important; }
        .apexcharts-menu-item { color: #E2E8F0 !important; }
        .apexcharts-menu-item:hover { background: #334155 !important; }

        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); width: 260px; }
            .sidebar.open { transform: translateX(0); box-shadow: 4px 0 16px rgba(0,0,0,0.4); }
            .main-content, .footer, .topbar { margin-left: 0; left: 0; }
            .sidebar-toggle { display: block; }

            /* Touch-friendly tap targets */
            .sidebar-link { padding: 14px 20px; font-size: 15px; }
            .btn, .form-select, .form-control { min-height: 42px; font-size: 16px; }
            .btn-sm { min-height: 36px; }

            /* Stack KPI/summary card rows on small screens, full width */
            .row > [class*="col-"] { margin-bottom: 8px; }

            /* Shrink page padding to reclaim screen space */
            .main-content > main > div { padding: 12px !important; }

            /* Tables: allow horizontal scroll instead of squeezing columns unreadable */
            .table-responsive, table { display: block; overflow-x: auto; white-space: nowrap; }

            /* Charts: cap height so they don't dominate the viewport on small screens */
            div[id$="Chart"] { max-height: 280px !important; }
        }

        @@media (max-width: 480px) {
            .topbar-title { font-size: 12px; }
            h1.h2 { font-size: 20px; }
            div[id$="Chart"] { max-height: 220px !important; }
        }
    </style>
</head>
<body>
    @{
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    }

    <!-- Sidebar -->
    @{
        // Each group: (id, label, controllers-in-group). "has-active" / auto-expand is computed
        // server-side from the current controller so the page you're on is never hidden behind
        // a collapsed group on load. Collapse state for groups NOT containing the active page is
        // persisted client-side via localStorage (see script at bottom).
        var groups = new (string Id, string Label, string[] Controllers)[]
        {
            ("overview", "Overview", new[] { "Briefing", "MyDashboard", "Dashboard" }),
            ("live", "Live Operations", new[] { "LiveMonitoring", "MeterDetails", "FloorMap", "Alarm", "AlarmResponse", "RootCause" }),
            ("finance", "Financial", new[] { "CostDashboard", "Budget", "Qbr", "Carbon", "PfPenalty", "WhatIf" }),
            ("powerquality", "Power Quality & Engineering", new[] { "PowerQuality", "VoltageImbalance", "LineVoltageBalance", "VoltageRange", "Frequency", "ReactivePower", "EquipmentHealth", "TransformerLoading", "DiversityFactor", "CapacityHeadroom" }),
            ("usage", "Usage Patterns", new[] { "TimeOfUse", "DemandCurve", "Heatmap", "Anomaly", "Forecast" }),
            ("devices", "Devices & Comparison", new[] { "MeterFaceplate", "Comparison", "EnergyAnalysis", "Sankey", "FlowMonitoring" }),
            ("reports", "Reports & Data", new[] { "Reports", "DataQuality", "Weather" }),
            ("admin", "Admin", new[] { "Settings" }),
        };
    }
    <nav class="sidebar" id="sidebar">
        <a class="sidebar-brand" asp-controller="Dashboard" asp-action="Index">EMS</a>

        <div class="sidebar-search-wrap">
            <input type="text" id="sidebarSearch" class="sidebar-search" placeholder="Search pages..." autocomplete="off" />
        </div>

        <div class="sidebar-nav" id="sidebarNav">
            @foreach (var g in groups)
            {
                var isActiveGroup = g.Controllers.Contains(ctrl);
                <div class="sidebar-group @(isActiveGroup ? "has-active" : "")" data-group-id="@g.Id">
                    <div class="sidebar-group-header" onclick="toggleGroup(this)">
                        <span>@g.Label</span>
                        <span class="sidebar-group-caret">&#9660;</span>
                    </div>
                    <div class="sidebar-group-links">
                        @if (g.Id == "overview")
                        {
                            <a class="sidebar-link @(ctrl == "Briefing" ? "active" : "")" asp-controller="Briefing" asp-action="Index"><span class="sidebar-icon">&#9733;</span> Briefing</a>
                            <a class="sidebar-link @(ctrl == "MyDashboard" ? "active" : "")" asp-controller="MyDashboard" asp-action="Index"><span class="sidebar-icon">&#9783;</span> My Dashboard</a>
                            <a class="sidebar-link @(ctrl == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index"><span class="sidebar-icon">&#9632;</span> Dashboard</a>
                        }
                        else if (g.Id == "live")
                        {
                            <a class="sidebar-link @(ctrl == "LiveMonitoring" || ctrl == "MeterDetails" ? "active" : "")" asp-controller="LiveMonitoring" asp-action="Index"><span class="sidebar-icon">&#9673;</span> Live Monitoring</a>
                            <a class="sidebar-link @(ctrl == "FloorMap" ? "active" : "")" asp-controller="FloorMap" asp-action="Index"><span class="sidebar-icon">&#127970;</span> Floor Map</a>
                            <a class="sidebar-link @(ctrl == "Alarm" ? "active" : "")" asp-controller="Alarm" asp-action="Index"><span class="sidebar-icon">&#9888;</span> Alarms</a>
                            <a class="sidebar-link @(ctrl == "AlarmResponse" ? "active" : "")" asp-controller="AlarmResponse" asp-action="Index"><span class="sidebar-icon">&#9203;</span> Response Time</a>
                            <a class="sidebar-link @(ctrl == "RootCause" ? "active" : "")" asp-controller="RootCause" asp-action="Index"><span class="sidebar-icon">&#128269;</span> Root Cause Context</a>
                        }
                        else if (g.Id == "finance")
                        {
                            <a class="sidebar-link @(ctrl == "CostDashboard" ? "active" : "")" asp-controller="CostDashboard" asp-action="Index"><span class="sidebar-icon">Rs</span> Cost Dashboard</a>
                            <a class="sidebar-link @(ctrl == "Budget" ? "active" : "")" asp-controller="Budget" asp-action="Index"><span class="sidebar-icon">&#128181;</span> Budget vs Actual</a>
                            <a class="sidebar-link @(ctrl == "Qbr" ? "active" : "")" asp-controller="Qbr" asp-action="Index"><span class="sidebar-icon">&#128203;</span> Executive QBR</a>
                            <a class="sidebar-link @(ctrl == "Carbon" ? "active" : "")" asp-controller="Carbon" asp-action="Index"><span class="sidebar-icon">&#127807;</span> Carbon / ESG</a>
                            <a class="sidebar-link @(ctrl == "PfPenalty" ? "active" : "")" asp-controller="PfPenalty" asp-action="Index"><span class="sidebar-icon">&#128202;</span> PF Penalty Calculator</a>
                            <a class="sidebar-link @(ctrl == "WhatIf" ? "active" : "")" asp-controller="WhatIf" asp-action="Index"><span class="sidebar-icon">&#127919;</span> What-If Modeler</a>
                        }
                        else if (g.Id == "powerquality")
                        {
                            <a class="sidebar-link @(ctrl == "PowerQuality" ? "active" : "")" asp-controller="PowerQuality" asp-action="Index"><span class="sidebar-icon">&#9889;</span> Power Quality</a>
                            <a class="sidebar-link @(ctrl == "VoltageImbalance" ? "active" : "")" asp-controller="VoltageImbalance" asp-action="Index"><span class="sidebar-icon">&#9889;</span> Voltage Imbalance</a>
                            <a class="sidebar-link @(ctrl == "LineVoltageBalance" ? "active" : "")" asp-controller="LineVoltageBalance" asp-action="Index"><span class="sidebar-icon">&#9889;</span> Line Voltage Balance</a>
                            <a class="sidebar-link @(ctrl == "VoltageRange" ? "active" : "")" asp-controller="VoltageRange" asp-action="Index"><span class="sidebar-icon">&#9889;</span> Voltage Out-of-Range</a>
                            <a class="sidebar-link @(ctrl == "Frequency" ? "active" : "")" asp-controller="Frequency" asp-action="Index"><span class="sidebar-icon">&#9889;</span> Frequency Stability</a>
                            <a class="sidebar-link @(ctrl == "ReactivePower" ? "active" : "")" asp-controller="ReactivePower" asp-action="Index"><span class="sidebar-icon">&#8645;</span> Reactive Power</a>
                            <a class="sidebar-link @(ctrl == "EquipmentHealth" ? "active" : "")" asp-controller="EquipmentHealth" asp-action="Index"><span class="sidebar-icon">&#128295;</span> Equipment Health</a>
                            <a class="sidebar-link @(ctrl == "TransformerLoading" ? "active" : "")" asp-controller="TransformerLoading" asp-action="Index"><span class="sidebar-icon">&#9881;</span> Transformer Loading</a>
                            <a class="sidebar-link @(ctrl == "DiversityFactor" ? "active" : "")" asp-controller="DiversityFactor" asp-action="Index"><span class="sidebar-icon">&#9881;</span> Diversity Factor</a>
                            <a class="sidebar-link @(ctrl == "CapacityHeadroom" ? "active" : "")" asp-controller="CapacityHeadroom" asp-action="Index"><span class="sidebar-icon">&#9881;</span> Capacity Headroom</a>
                        }
                        else if (g.Id == "usage")
                        {
                            <a class="sidebar-link @(ctrl == "TimeOfUse" ? "active" : "")" asp-controller="TimeOfUse" asp-action="Index"><span class="sidebar-icon">&#9201;</span> Time-of-Use Analysis</a>
                            <a class="sidebar-link @(ctrl == "DemandCurve" ? "active" : "")" asp-controller="DemandCurve" asp-action="Index"><span class="sidebar-icon">&#128200;</span> Demand Curve</a>
                            <a class="sidebar-link @(ctrl == "Heatmap" ? "active" : "")" asp-controller="Heatmap" asp-action="Index"><span class="sidebar-icon">&#128293;</span> Consumption Heatmap</a>
                            <a class="sidebar-link @(ctrl == "Anomaly" ? "active" : "")" asp-controller="Anomaly" asp-action="Index"><span class="sidebar-icon">&#128269;</span> Anomaly Detection</a>
                            <a class="sidebar-link @(ctrl == "Forecast" ? "active" : "")" asp-controller="Forecast" asp-action="Index"><span class="sidebar-icon">&#128302;</span> Trend Projection</a>
                        }
                        else if (g.Id == "devices")
                        {
                            <a class="sidebar-link @(ctrl == "MeterFaceplate" ? "active" : "")" asp-controller="MeterFaceplate" asp-action="Index"><span class="sidebar-icon">&#9889;</span> Meter Faceplate</a>
                            <a class="sidebar-link @(ctrl == "Comparison" ? "active" : "")" asp-controller="Comparison" asp-action="Index"><span class="sidebar-icon">&#8651;</span> Meter Comparison</a>
                            <a class="sidebar-link @(ctrl == "EnergyAnalysis" ? "active" : "")" asp-controller="EnergyAnalysis" asp-action="Index"><span class="sidebar-icon">&#9650;</span> Energy Analysis</a>
                            <a class="sidebar-link @(ctrl == "Sankey" ? "active" : "")" asp-controller="Sankey" asp-action="Index"><span class="sidebar-icon">&#8651;</span> Energy Flow</a>
                            <a class="sidebar-link @(ctrl == "FlowMonitoring" ? "active" : "")" asp-controller="FlowMonitoring" asp-action="Index"><span class="sidebar-icon">&#128167;</span> Flow & Level</a>
                        }
                        else if (g.Id == "reports")
                        {
                            <a class="sidebar-link @(ctrl == "Reports" ? "active" : "")" asp-controller="Reports" asp-action="Index"><span class="sidebar-icon">&#9776;</span> Reports</a>
                            <a class="sidebar-link @(ctrl == "DataQuality" ? "active" : "")" asp-controller="DataQuality" asp-action="Index"><span class="sidebar-icon">&#10003;</span> Data Quality</a>
                            <a class="sidebar-link @(ctrl == "Weather" ? "active" : "")" asp-controller="Weather" asp-action="Index"><span class="sidebar-icon">&#127777;</span> Weather Correlation</a>
                        }
                        else if (g.Id == "admin")
                        {
                            <a class="sidebar-link @(ctrl == "Settings" ? "active" : "")" asp-controller="Settings" asp-action="Index"><span class="sidebar-icon">&#9881;</span> Settings</a>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="sidebar-footer">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="sidebar-user" title="@User.Identity.Name">@User.Identity.Name</div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100" style="font-size: 12px;">Logout</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-primary w-100" style="font-size: 12px;">Login</a>
            }
        </div>
    </nav>

    <!-- Top Bar -->
    <div class="topbar">
        <div class="d-flex align-items-center gap-3">
            <button class="sidebar-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">&#9776;</button>
            <span class="topbar-title">@ViewData["Title"]</span>
        </div>
        <div class="topbar-actions">
            <a asp-controller="Dashboard" asp-action="Index" style="color: var(--text-secondary); text-decoration: none; font-size: 13px;">Home</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-center py-3">
        <small>&copy; 2026 Energy Monitoring System. All rights reserved.</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Sidebar group collapse state, persisted per-browser. A group containing the
        // current page is always expanded on load regardless of saved state, so you can
        // never land on a page whose own nav entry is hidden behind a collapsed group.
        (function () {
            var STORAGE_KEY = 'ems_sidebar_collapsed_groups';

            function getCollapsedSet() {
                try { return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]')); }
                catch (e) { return new Set(); }
            }
            function saveCollapsedSet(set) {
                try { localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(set))); } catch (e) { }
            }

            window.toggleGroup = function (headerEl) {
                var group = headerEl.closest('.sidebar-group');
                var id = group.getAttribute('data-group-id');
                var collapsed = getCollapsedSet();
                group.classList.toggle('collapsed');
                if (group.classList.contains('collapsed')) { collapsed.add(id); } else { collapsed.delete(id); }
                saveCollapsedSet(collapsed);
            };

            document.addEventListener('DOMContentLoaded', function () {
                var collapsed = getCollapsedSet();
                document.querySelectorAll('.sidebar-group').forEach(function (group) {
                    var id = group.getAttribute('data-group-id');
                    var isActiveGroup = group.classList.contains('has-active');
                    if (!isActiveGroup && collapsed.has(id)) {
                        group.classList.add('collapsed');
                    }
                });

                // Live search: filters individual links by text, auto-expands any group with a match.
                var searchInput = document.getElementById('sidebarSearch');
                if (searchInput) {
                    searchInput.addEventListener('input', function () {
                        var q = this.value.trim().toLowerCase();
                        document.querySelectorAll('.sidebar-group').forEach(function (group) {
                            var anyMatch = false;
                            group.querySelectorAll('.sidebar-link').forEach(function (link) {
                                var text = link.textContent.trim().toLowerCase();
                                var matches = q === '' || text.indexOf(q) !== -1;
                                link.classList.toggle('hidden-by-search', !matches);
                                if (matches) anyMatch = true;
                            });
                            if (q === '') {
                                group.style.display = '';
                                group.classList.toggle('collapsed', collapsed.has(group.getAttribute('data-group-id')) && !group.classList.contains('has-active'));
                            } else {
                                group.style.display = anyMatch ? '' : 'none';
                                if (anyMatch) group.classList.remove('collapsed');
                            }
                        });
                    });
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
