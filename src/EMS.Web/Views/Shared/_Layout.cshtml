<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Energy Monitoring System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --sidebar-width: 220px;
            --topbar-height: 50px;
            --bg-primary: #0F172A;
            --bg-secondary: #1E293B;
            --bg-tertiary: #334155;
            --text-primary: #E2E8F0;
            --text-secondary: #94A3B8;
            --text-muted: #64748B;
            --accent: #2563EB;
            --border: #334155;
        }

        body { background-color: var(--bg-primary); color: var(--text-primary); margin: 0; overflow-x: hidden; }

        .sidebar {
            position: fixed; top: 0; left: 0; bottom: 0;
            width: var(--sidebar-width);
            background-color: var(--bg-secondary);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            z-index: 1000;
            transition: transform 0.2s;
        }

        .sidebar-brand {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 18px; font-weight: 700;
            color: var(--accent);
            text-decoration: none; display: block;
        }

        .sidebar-nav { flex: 1; padding: 12px 0; overflow-y: auto; }

        .sidebar-section { padding: 8px 20px 4px; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); }

        .sidebar-link {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 20px;
            color: var(--text-secondary);
            text-decoration: none; font-size: 14px;
            transition: background-color 0.15s, color 0.15s;
            border-left: 3px solid transparent;
        }
        .sidebar-link:hover { background-color: var(--bg-tertiary); color: var(--text-primary); }
        .sidebar-link.active { color: var(--accent); background-color: rgba(37, 99, 235, 0.1); border-left-color: var(--accent); font-weight: 600; }

        .sidebar-icon { width: 18px; text-align: center; font-size: 14px; }

        .sidebar-footer {
            padding: 12px 20px;
            border-top: 1px solid var(--border);
            font-size: 12px;
        }

        .sidebar-user { color: var(--text-secondary); margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        .topbar {
            position: fixed; top: 0; left: var(--sidebar-width); right: 0;
            height: var(--topbar-height);
            background-color: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 24px;
            z-index: 999;
        }

        .topbar-title { font-size: 14px; color: var(--text-primary); font-weight: 500; }
        .topbar-actions { display: flex; align-items: center; gap: 12px; }

        .main-content {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            min-height: calc(100vh - var(--topbar-height));
        }

        .footer {
            margin-left: var(--sidebar-width);
            background-color: var(--bg-secondary);
            border-top: 1px solid var(--border);
            color: var(--text-muted);
        }

        .sidebar-toggle { display: none; background: none; border: none; color: var(--text-primary); font-size: 20px; cursor: pointer; }

        .apexcharts-menu { background: #1E293B !important; border-color: #334155 !important; }
        .apexcharts-menu-item { color: #E2E8F0 !important; }
        .apexcharts-menu-item:hover { background: #334155 !important; }

        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); width: 260px; }
            .sidebar.open { transform: translateX(0); box-shadow: 4px 0 16px rgba(0,0,0,0.4); }
            .main-content, .footer, .topbar { margin-left: 0; left: 0; }
            .sidebar-toggle { display: block; }

            /* Touch-friendly tap targets */
            .sidebar-link { padding: 14px 20px; font-size: 15px; }
            .btn, .form-select, .form-control { min-height: 42px; font-size: 16px; }
            .btn-sm { min-height: 36px; }

            /* Stack KPI/summary card rows on small screens, full width */
            .row > [class*="col-"] { margin-bottom: 8px; }

            /* Shrink page padding to reclaim screen space */
            .main-content > main > div { padding: 12px !important; }

            /* Tables: allow horizontal scroll instead of squeezing columns unreadable */
            .table-responsive, table { display: block; overflow-x: auto; white-space: nowrap; }

            /* Charts: cap height so they don't dominate the viewport on small screens */
            div[id$="Chart"] { max-height: 280px !important; }
        }

        @@media (max-width: 480px) {
            .topbar-title { font-size: 12px; }
            h1.h2 { font-size: 20px; }
            div[id$="Chart"] { max-height: 220px !important; }
        }
    </style>
</head>
<body>
    @{
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    }

    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
        <a class="sidebar-brand" asp-controller="Dashboard" asp-action="Index">EMS</a>

        <div class="sidebar-nav">
            <a class="sidebar-link @(ctrl == "Briefing" ? "active" : "")" asp-controller="Briefing" asp-action="Index" style="@(ctrl == "Briefing" ? "background: rgba(37,99,235,0.15);" : "")">
                <span class="sidebar-icon">&#9733;</span> Briefing
            </a>
            <a class="sidebar-link @(ctrl == "MyDashboard" ? "active" : "")" asp-controller="MyDashboard" asp-action="Index">
                <span class="sidebar-icon">&#9783;</span> My Dashboard
            </a>

            <div class="sidebar-section">Monitoring</div>
            <a class="sidebar-link @(ctrl == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                <span class="sidebar-icon">&#9632;</span> Dashboard
            </a>
            <a class="sidebar-link @(ctrl == "LiveMonitoring" || ctrl == "MeterDetails" ? "active" : "")" asp-controller="LiveMonitoring" asp-action="Index">
                <span class="sidebar-icon">&#9673;</span> Live Monitoring
            </a>
            <a class="sidebar-link @(ctrl == "FloorMap" ? "active" : "")" asp-controller="FloorMap" asp-action="Index">
                <span class="sidebar-icon">&#127970;</span> Floor Map
            </a>

            <div class="sidebar-section">Operations</div>
            <a class="sidebar-link @(ctrl == "Alarm" ? "active" : "")" asp-controller="Alarm" asp-action="Index">
                <span class="sidebar-icon">&#9888;</span> Alarms
            </a>
            <a class="sidebar-link @(ctrl == "AlarmResponse" ? "active" : "")" asp-controller="AlarmResponse" asp-action="Index">
                <span class="sidebar-icon">&#9203;</span> Response Time
            </a>

            <div class="sidebar-section">Finance</div>
            <a class="sidebar-link @(ctrl == "CostDashboard" ? "active" : "")" asp-controller="CostDashboard" asp-action="Index">
                <span class="sidebar-icon">Rs</span> Cost Dashboard
            </a>

            <div class="sidebar-section">Devices</div>
            <a class="sidebar-link @(ctrl == "MeterFaceplate" ? "active" : "")" asp-controller="MeterFaceplate" asp-action="Index">
                <span class="sidebar-icon">&#9889;</span> Meter Faceplate
            </a>

            <div class="sidebar-section">Analysis</div>
            <a class="sidebar-link @(ctrl == "EnergyAnalysis" ? "active" : "")" asp-controller="EnergyAnalysis" asp-action="Index">
                <span class="sidebar-icon">&#9650;</span> Energy Analysis
            </a>
            <a class="sidebar-link @(ctrl == "Comparison" ? "active" : "")" asp-controller="Comparison" asp-action="Index">
                <span class="sidebar-icon">&#8651;</span> Meter Comparison
            </a>
            <a class="sidebar-link @(ctrl == "PowerQuality" ? "active" : "")" asp-controller="PowerQuality" asp-action="Index">
                <span class="sidebar-icon">&#9889;</span> Power Quality
            </a>
            <a class="sidebar-link @(ctrl == "ShiftAnalysis" ? "active" : "")" asp-controller="ShiftAnalysis" asp-action="Index">
                <span class="sidebar-icon">&#9201;</span> Shift Comparison
            </a>
            <a class="sidebar-link @(ctrl == "Baseload" ? "active" : "")" asp-controller="Baseload" asp-action="Index">
                <span class="sidebar-icon">&#128176;</span> Baseload Analysis
            </a>
            <a class="sidebar-link @(ctrl == "DemandCurve" ? "active" : "")" asp-controller="DemandCurve" asp-action="Index">
                <span class="sidebar-icon">&#128200;</span> Demand Curve
            </a>
            <a class="sidebar-link @(ctrl == "DiversityFactor" ? "active" : "")" asp-controller="DiversityFactor" asp-action="Index">
                <span class="sidebar-icon">&#9881;</span> Diversity Factor
            </a>
            <a class="sidebar-link @(ctrl == "Frequency" ? "active" : "")" asp-controller="Frequency" asp-action="Index">
                <span class="sidebar-icon">&#9889;</span> Frequency Stability
            </a>
            <a class="sidebar-link @(ctrl == "ReactivePower" ? "active" : "")" asp-controller="ReactivePower" asp-action="Index">
                <span class="sidebar-icon">&#8645;</span> Reactive Power
            </a>
            <a class="sidebar-link @(ctrl == "LineVoltageBalance" ? "active" : "")" asp-controller="LineVoltageBalance" asp-action="Index">
                <span class="sidebar-icon">&#9889;</span> Line Voltage Balance
            </a>
            <a class="sidebar-link @(ctrl == "Carbon" ? "active" : "")" asp-controller="Carbon" asp-action="Index">
                <span class="sidebar-icon">&#127807;</span> Carbon / ESG
            </a>
            <a class="sidebar-link @(ctrl == "FlowMonitoring" ? "active" : "")" asp-controller="FlowMonitoring" asp-action="Index">
                <span class="sidebar-icon">&#128167;</span> Flow & Level
            </a>
            <a class="sidebar-link @(ctrl == "VoltageRange" ? "active" : "")" asp-controller="VoltageRange" asp-action="Index">
                <span class="sidebar-icon">&#9889;</span> Voltage Out-of-Range
            </a>
            <a class="sidebar-link @(ctrl == "WeekdayWeekend" ? "active" : "")" asp-controller="WeekdayWeekend" asp-action="Index">
                <span class="sidebar-icon">&#128197;</span> Weekday/Weekend
            </a>
            <a class="sidebar-link @(ctrl == "Budget" ? "active" : "")" asp-controller="Budget" asp-action="Index">
                <span class="sidebar-icon">&#128181;</span> Budget vs Actual
            </a>
            <a class="sidebar-link @(ctrl == "VoltageImbalance" ? "active" : "")" asp-controller="VoltageImbalance" asp-action="Index">
                <span class="sidebar-icon">&#9889;</span> Voltage Imbalance
            </a>
            <a class="sidebar-link @(ctrl == "PfPenalty" ? "active" : "")" asp-controller="PfPenalty" asp-action="Index">
                <span class="sidebar-icon">&#128202;</span> PF Penalty Calculator
            </a>
            <a class="sidebar-link @(ctrl == "Heatmap" ? "active" : "")" asp-controller="Heatmap" asp-action="Index">
                <span class="sidebar-icon">&#128293;</span> Consumption Heatmap
            </a>
            <a class="sidebar-link @(ctrl == "EquipmentHealth" ? "active" : "")" asp-controller="EquipmentHealth" asp-action="Index">
                <span class="sidebar-icon">&#128295;</span> Equipment Health
            </a>
            <a class="sidebar-link @(ctrl == "Anomaly" ? "active" : "")" asp-controller="Anomaly" asp-action="Index">
                <span class="sidebar-icon">&#128269;</span> Anomaly Detection
            </a>
            <a class="sidebar-link @(ctrl == "Sankey" ? "active" : "")" asp-controller="Sankey" asp-action="Index">
                <span class="sidebar-icon">&#8651;</span> Energy Flow
            </a>
            <a class="sidebar-link @(ctrl == "Forecast" ? "active" : "")" asp-controller="Forecast" asp-action="Index">
                <span class="sidebar-icon">&#128302;</span> Forecast
            </a>
            <a class="sidebar-link @(ctrl == "WhatIf" ? "active" : "")" asp-controller="WhatIf" asp-action="Index">
                <span class="sidebar-icon">&#127919;</span> What-If Modeler
            </a>
            <a class="sidebar-link @(ctrl == "DataQuality" ? "active" : "")" asp-controller="DataQuality" asp-action="Index">
                <span class="sidebar-icon">&#10003;</span> Data Quality
            </a>
            <a class="sidebar-link @(ctrl == "Weather" ? "active" : "")" asp-controller="Weather" asp-action="Index">
                <span class="sidebar-icon">&#127777;</span> Weather Correlation
            </a>
            <a class="sidebar-link @(ctrl == "Qbr" ? "active" : "")" asp-controller="Qbr" asp-action="Index">
                <span class="sidebar-icon">&#128203;</span> Executive QBR
            </a>
            <a class="sidebar-link @(ctrl == "Reports" ? "active" : "")" asp-controller="Reports" asp-action="Index">
                <span class="sidebar-icon">&#9776;</span> Reports
            </a>
        </div>

            <div class="sidebar-section">Admin</div>
            <a class="sidebar-link @(ctrl == "Settings" ? "active" : "")" asp-controller="Settings" asp-action="Index">
                <span class="sidebar-icon">&#9881;</span> Settings
            </a>

        <div class="sidebar-footer">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="sidebar-user" title="@User.Identity.Name">@User.Identity.Name</div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger w-100" style="font-size: 12px;">Logout</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-primary w-100" style="font-size: 12px;">Login</a>
            }
        </div>
    </nav>

    <!-- Top Bar -->
    <div class="topbar">
        <div class="d-flex align-items-center gap-3">
            <button class="sidebar-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">&#9776;</button>
            <span class="topbar-title">@ViewData["Title"]</span>
        </div>
        <div class="topbar-actions">
            <a asp-controller="Dashboard" asp-action="Index" style="color: var(--text-secondary); text-decoration: none; font-size: 13px;">Home</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-center py-3">
        <small>&copy; 2026 Energy Monitoring System. All rights reserved.</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
