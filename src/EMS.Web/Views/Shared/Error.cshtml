@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">
    <div class="state-card state-error" style="max-width: 640px; margin: 60px auto;">
        <div class="state-icon"><i class="bi bi-exclamation-octagon-fill"></i></div>
        <h4>Something went wrong loading this page</h4>
        <p>The error has been logged. Try going back, or head to the Dashboard.</p>

        @if (Model != null && Model.ShowRequestId)
        {
            <p style="margin-top: 12px; font-size: 12px; color: #64748B;">
                Request ID: <code style="color: #94A3B8;">@Model.RequestId</code>
            </p>
        }

        <div style="margin-top: 20px; display: flex; gap: 12px; justify-content: center;">
            <a href="javascript:history.back()" class="btn btn-sm" style="background: #334155; color: #E2E8F0; border: none; padding: 8px 18px;">
                <i class="bi bi-arrow-left"></i> Go Back
            </a>
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-sm" style="background: #2563EB; color: white; border: none; padding: 8px 18px;">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>
        </div>
    </div>
</div>
