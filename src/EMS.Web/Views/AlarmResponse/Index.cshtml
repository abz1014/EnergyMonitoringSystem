@{
    ViewData["Title"] = "Alarm Response Time";
    var hasData = (bool)(ViewBag.HasData ?? false);
    var hasResponseData = (bool)(ViewBag.HasResponseData ?? false);
    var bySeverity = ViewBag.BySeverity as IEnumerable<dynamic>;
    var byUser = ViewBag.ByUser as IEnumerable<dynamic>;
    var slowestAlarms = ViewBag.SlowestAlarms as IEnumerable<dynamic>;
}

@functions {
    string FormatMinutes(double minutes)
    {
        if (minutes < 60) return $"{minutes:F0} min";
        if (minutes < 1440) return $"{minutes / 60:F1} hr";
        return $"{minutes / 1440:F1} days";
    }
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">
    <div class="mb-4">
        <h1 class="h2 mb-2">Alarm Response Time</h1>
        <p class="text-muted">How quickly alarms get acknowledged — identifies miscalibrated thresholds and slow response patterns</p>
    </div>

    @if (hasData)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid #3B82F6;">
                    <div style="color: #94A3B8; font-size: 12px; text-transform: uppercase;">Total Alarms</div>
                    <div style="color: #FFFFFF; font-size: 26px; font-weight: 700;">@ViewBag.TotalAlarms</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid #10B981;">
                    <div style="color: #94A3B8; font-size: 12px; text-transform: uppercase;">Acknowledged</div>
                    <div style="color: #10B981; font-size: 26px; font-weight: 700;">@ViewBag.AckedCount</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid @((int)ViewBag.UnackedCount > 0 ? "#EF4444" : "#94A3B8");">
                    <div style="color: #94A3B8; font-size: 12px; text-transform: uppercase;">Still Unacknowledged</div>
                    <div style="color: @((int)ViewBag.UnackedCount > 0 ? "#EF4444" : "#FFFFFF"); font-size: 26px; font-weight: 700;">@ViewBag.UnackedCount</div>
                </div>
            </div>
        </div>

        @if (hasResponseData)
        {
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="p-3" style="background-color: #1E293B; border-radius: 8px;">
                        <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Average Response</div>
                        <div style="color: #FFFFFF; font-size: 20px; font-weight: 700;">@FormatMinutes((double)ViewBag.AvgResponseMin)</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3" style="background-color: #1E293B; border-radius: 8px;">
                        <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Median Response</div>
                        <div style="color: #FFFFFF; font-size: 20px; font-weight: 700;">@FormatMinutes((double)ViewBag.MedianResponseMin)</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3" style="background-color: #1E293B; border-radius: 8px;">
                        <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Fastest</div>
                        <div style="color: #10B981; font-size: 20px; font-weight: 700;">@FormatMinutes((double)ViewBag.FastestResponseMin)</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3" style="background-color: #1E293B; border-radius: 8px;">
                        <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Slowest</div>
                        <div style="color: #EF4444; font-size: 20px; font-weight: 700;">@FormatMinutes((double)ViewBag.SlowestResponseMin)</div>
                    </div>
                </div>
            </div>

            <div class="mb-3 p-2" style="background-color: #1E293B; border-radius: 6px; border-left: 3px solid #94A3B8; font-size: 12px; color: #94A3B8;">
                Sample size: @ViewBag.AckedCount acknowledged alarms. With a small sample, these statistics are indicative, not statistically robust —
                treat as directional until more alarm history accumulates.
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                        <h6 class="text-light mb-3">Response Time by Severity</h6>
                        @if (bySeverity != null)
                        {
                            @foreach (var s in bySeverity)
                            {
                                var color = s.SeverityName == "Critical" ? "#EF4444" : s.SeverityName == "Warning" ? "#F59E0B" : "#3B82F6";
                                <div class="d-flex justify-content-between mb-2" style="font-size: 13px;">
                                    <span style="color:@color;">@s.SeverityName (@s.Count)</span>
                                    <span style="color:#E2E8F0;">@FormatMinutes((double)s.AvgMinutes) avg</span>
                                </div>
                            }
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                        <h6 class="text-light mb-3">Response Time by Acknowledger</h6>
                        @if (byUser != null && byUser.Any())
                        {
                            @foreach (var u in byUser)
                            {
                                <div class="d-flex justify-content-between mb-2" style="font-size: 13px;">
                                    <span style="color:#94A3B8;">@u.User (@u.Count)</span>
                                    <span style="color:#E2E8F0;">@FormatMinutes((double)u.AvgMinutes) avg</span>
                                </div>
                            }
                        }
                        else
                        {
                            <small style="color: #64748B;">No acknowledger data recorded.</small>
                        }
                    </div>
                </div>
            </div>

            <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                <h6 class="text-light mb-3">Slowest Responses</h6>
                <table class="table table-dark table-sm" style="background-color: transparent;">
                    <thead>
                        <tr style="color: #94A3B8; font-size: 12px;">
                            <th>Device</th><th>Message</th><th>Severity</th><th>Raised At</th><th>Response Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (slowestAlarms != null)
                        {
                            @foreach (var a in slowestAlarms)
                            {
                                <tr style="font-size: 13px;">
                                    <td>
                                        @if (((string)a.DeviceName).Contains("Meter"))
                                        {
                                            <a href="/MeterFaceplate?meterId=@a.DeviceID" style="color: #E2E8F0; text-decoration: underline; text-decoration-color: #334155;">@a.DeviceName</a>
                                        }
                                        else
                                        {
                                            @a.DeviceName
                                        }
                                    </td>
                                    <td>@a.Message</td>
                                    <td>@a.SeverityName</td>
                                    <td>@(((DateTime)a.CreatedAt).ToString("MMM dd, HH:mm"))</td>
                                    <td>@FormatMinutes((double)a.ResponseMinutes)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-5 text-center" style="background-color: #1E293B; border-radius: 8px;">
                <div style="font-size: 48px; color: #64748B;">&#9203;</div>
                <h4 style="color: #E2E8F0;">No alarms have been acknowledged yet</h4>
                <p style="color: #64748B;">Response time analytics will appear once alarms are acknowledged.</p>
            </div>
        }
    }
    else
    {
        <div class="p-5 text-center" style="background-color: #1E293B; border-radius: 8px;">
            <div style="font-size: 48px; color: #64748B;">&#9203;</div>
            <h4 style="color: #E2E8F0;">No alarm data available</h4>
        </div>
    }
</div>
