@model object
@{
    ViewData["Title"] = "Weather Correlation";
    var hasData = (bool)(ViewBag.HasData ?? false);
    var range = ViewBag.Range as string ?? "30d";
    var allTemps = ViewBag.AllTemps as List<EMS.Core.Models.DailyTemperature> ?? new();
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">
    <div class="mb-4">
        <h1 class="h2 mb-2">Weather Correlation</h1>
        <p class="text-muted">Relationship between daily average temperature and energy consumption</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <form method="get" class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label text-light">Time Range</label>
                        <select name="range" class="form-select" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;">
                            @foreach (var (val, label) in new[] { ("7d","Last 7 Days"), ("30d","Last 30 Days"), ("90d","Last 90 Days") })
                            {
                                if (range == val) { <option value="@val" selected>@label</option> } else { <option value="@val">@label</option> }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100" style="background-color: #2563EB;">Analyze</button>
                    </div>
                </div>
            </form>
        </div>
        <div class="col-md-4">
            <form method="post" asp-action="AddTemperature" class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                @Html.AntiForgeryToken()
                <label class="form-label text-light" style="font-size:12px;">Add/Update Daily Temperature</label>
                <div class="d-flex gap-2">
                    <input type="date" name="tempDate" class="form-control form-control-sm" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;" required />
                    <input type="number" name="avgTempC" step="0.1" placeholder="°C" class="form-control form-control-sm" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155; width: 80px;" required />
                    <button type="submit" class="btn btn-sm btn-outline-light">Save</button>
                </div>
            </form>
        </div>
    </div>

    @if (hasData)
    {
        var correlation = (double)ViewBag.Correlation;
        var corrColor = Math.Abs(correlation) >= 0.7 ? "#EF4444" : Math.Abs(correlation) >= 0.4 ? "#F59E0B" : "#94A3B8";

        <div style="color: #94A3B8; font-size: 13px; margin-bottom: 16px;">Period: @ViewBag.DateRangeLabel | @ViewBag.DataPoints matched day(s)</div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid @corrColor;">
                    <div style="color: #94A3B8; font-size: 12px; text-transform: uppercase;">Correlation Coefficient (r)</div>
                    <div style="color: @corrColor; font-size: 28px; font-weight: 700;">@correlation</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid @corrColor;">
                    <div style="color: #94A3B8; font-size: 12px; text-transform: uppercase;">Strength</div>
                    <div style="color: @corrColor; font-size: 22px; font-weight: 700;">@ViewBag.CorrelationStrength @(correlation > 0 ? "Positive" : correlation < 0 ? "Negative" : "")</div>
                </div>
            </div>
        </div>

        <div class="mb-4 p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid @corrColor;">
            <span style="color: #E2E8F0;">
                @if (Math.Abs(correlation) >= 0.4)
                {
                    <text>Consumption shows a <strong>@ViewBag.CorrelationStrength.ToString().ToLower() @(correlation > 0 ? "positive" : "negative")</strong> relationship with temperature
                    (r = @correlation) — @(correlation > 0 ? "higher temperatures tend to coincide with higher consumption (likely cooling load)." : "higher temperatures tend to coincide with lower consumption.")</text>
                }
                else
                {
                    <text>No meaningful correlation detected between temperature and consumption in this period (r = @correlation). Other factors likely dominate usage patterns.</text>
                }
            </span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                    <h5 class="text-light mb-3">Temperature vs Consumption (Scatter)</h5>
                    <div id="scatterChart" style="height: 350px;"></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                    <h5 class="text-light mb-3">Daily Trend</h5>
                    <div id="trendChart" style="height: 350px;"></div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="p-5 text-center" style="background-color: #1E293B; border-radius: 8px;">
            <div style="font-size: 48px; color: #64748B;">&#127777;</div>
            <h4 style="color: #E2E8F0;">Not enough matched temperature/consumption data</h4>
            <p style="color: #64748B;">Add at least 3 days of temperature data using the form above (matching dates with existing meter data) to see correlation analysis.</p>
        </div>
    }

    @if (allTemps.Count > 0)
    {
        <div class="mt-4 p-4" style="background-color: #1E293B; border-radius: 8px;">
            <h6 class="text-light mb-3">Recorded Temperatures</h6>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                @foreach (var t in allTemps)
                {
                    <span style="background: #334155; padding: 4px 10px; border-radius: 4px; font-size: 12px; color: #E2E8F0;">@t.TempDate.ToString("MMM dd"): @t.AvgTempC°C</span>
                }
            </div>
        </div>
    }
</div>

@if (hasData)
{
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@latest/dist/apexcharts.min.js"></script>
    <script>
        new ApexCharts(document.querySelector('#scatterChart'), {
            series: [{ name: 'Days', data: @Html.Raw(ViewBag.ScatterData) }],
            chart: { type: 'scatter', height: 350, background: '#1E293B', toolbar: { show: true } },
            colors: ['#2563EB'],
            xaxis: { title: { text: 'Temperature (°C)', style: { color: '#94A3B8' } }, labels: { style: { colors: '#94A3B8' } } },
            yaxis: { title: { text: 'Consumption (kWh)', style: { color: '#94A3B8' } }, labels: { style: { colors: '#94A3B8' } } },
            tooltip: { theme: 'dark' },
            grid: { borderColor: '#334155' }
        }).render();

        new ApexCharts(document.querySelector('#trendChart'), {
            series: [
                { name: 'Temperature (°C)', type: 'line', data: @Html.Raw(ViewBag.TempSeries) },
                { name: 'Consumption (kWh)', type: 'line', data: @Html.Raw(ViewBag.ConsumptionSeries) }
            ],
            chart: { height: 350, background: '#1E293B', toolbar: { show: true } },
            colors: ['#F59E0B', '#2563EB'],
            stroke: { curve: 'smooth', width: 2 },
            xaxis: { categories: @Html.Raw(ViewBag.Dates), labels: { style: { colors: '#94A3B8', fontSize: '10px' }, rotate: -45 } },
            yaxis: [
                { title: { text: 'Temp (°C)', style: { color: '#F59E0B' } }, labels: { style: { colors: '#94A3B8' } } },
                { opposite: true, title: { text: 'kWh', style: { color: '#2563EB' } }, labels: { style: { colors: '#94A3B8' } } }
            ],
            tooltip: { theme: 'dark', shared: true },
            legend: { labels: { colors: '#94A3B8' }, position: 'top' },
            grid: { borderColor: '#334155' }
        }).render();
    </script>
}
