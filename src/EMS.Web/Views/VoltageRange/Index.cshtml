@{
    ViewData["Title"] = "Voltage Out-of-Range Duration";
    var hasData = (bool)(ViewBag.HasData ?? false);
    var range = ViewBag.Range as string ?? "7d";
    var rangePct = (double)(ViewBag.RangePct ?? 5.0);
    var nominalVoltage = (double)(ViewBag.NominalVoltage ?? 230.0);
    var worstEvents = ViewBag.WorstEvents as IEnumerable<dynamic>;
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;">
    <div class="mb-4">
        <h1 class="h2 mb-2">Voltage Out-of-Range Duration</h1>
        <p class="text-muted">% of periodic readings outside ANSI C84.1 Range A (±5% of nominal)</p>
    </div>

    <div class="mb-4 p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid #F59E0B;">
        <strong style="color: #F59E0B;">This is not voltage sag/swell detection.</strong>
        <span style="color: #E2E8F0;">
            True sag/swell events (IEEE 1159) last milliseconds and require sub-cycle event-triggered sampling that this system's
            periodic polling cannot provide. This page only shows how often <em>periodic snapshot readings</em> happen to fall
            outside the nominal voltage range — a much weaker, slower signal that will miss the vast majority of real power
            quality events. Treat this as a coarse indicator only, not a substitute for a dedicated power quality analyzer.
        </span>
    </div>

    <form method="get" class="mb-4 p-4" style="background-color: #1E293B; border-radius: 8px;">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label text-light">Time Range</label>
                <select name="range" class="form-select" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;">
                    @foreach (var (val, label) in new[] { ("7d","Last 7 Days"), ("30d","Last 30 Days"), ("90d","Last 90 Days") })
                    {
                        if (range == val) { <option value="@val" selected>@label</option> } else { <option value="@val">@label</option> }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label text-light">Range Band (± %)</label>
                <input type="number" name="rangePct" value="@rangePct" step="0.5" min="1" max="20" class="form-control"
                       style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100" style="background-color: #2563EB;">Analyze</button>
            </div>
        </div>
    </form>

    @if (hasData)
    {
        var outPct = (double)ViewBag.OutOfRangePct;
        var color = outPct > 5 ? "#EF4444" : outPct > 1 ? "#F59E0B" : "#10B981";

        <div style="color: #94A3B8; font-size: 13px; margin-bottom: 16px;">
            Period: @ViewBag.DateRangeLabel | Nominal: @nominalVoltage V | Range: @ViewBag.LowerBound — @ViewBag.UpperBound V | @ViewBag.TotalReadings readings
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid @color;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Out-of-Range Readings</div>
                    <div style="color: @color; font-size: 24px; font-weight: 700;">@ViewBag.OutOfRangeCount <span style="font-size:11px;color:#64748B;">(@outPct%)</span></div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="p-3" style="background-color: #1E293B; border-radius: 8px; border-left: 4px solid #F59E0B;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Estimated Duration</div>
                    <div style="color: #F59E0B; font-size: 24px; font-weight: 700;">~@ViewBag.EstimatedHours <span style="font-size:11px;color:#64748B;">hrs</span></div>
                </div>
            </div>
        </div>

        <div class="mb-4 p-4" style="background-color: #1E293B; border-radius: 8px;">
            <h5 class="text-light mb-3">Voltage Trend (3-phase)</h5>
            <div id="voltChart" style="height: 380px;"></div>
        </div>

        @if (worstEvents != null && worstEvents.Any())
        {
            <div class="p-4" style="background-color: #1E293B; border-radius: 8px;">
                <h5 class="text-light mb-3">Worst Out-of-Range Readings</h5>
                <table class="table table-dark table-sm" style="background-color: transparent;">
                    <thead>
                        <tr style="color: #94A3B8; font-size: 12px;">
                            <th>Time</th><th>L1N</th><th>L2N</th><th>L3N</th><th>Max Deviation</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in worstEvents)
                        {
                            <tr style="font-size: 13px;">
                                <td>@e.Time</td>
                                <td>@e.VoltL1N V</td>
                                <td>@e.VoltL2N V</td>
                                <td>@e.VoltL3N V</td>
                                <td style="color: #EF4444;">±@e.MaxDeviation V</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <div class="p-5 text-center" style="background-color: #1E293B; border-radius: 8px;">
            <div style="font-size: 48px; color: #64748B;">&#9889;</div>
            <h4 style="color: #E2E8F0;">No voltage data available for this period</h4>
        </div>
    }
</div>

@if (hasData)
{
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@latest/dist/apexcharts.min.js"></script>
    <script>
        new ApexCharts(document.querySelector('#voltChart'), {
            series: [
                { name: 'L1N', data: @Html.Raw(ViewBag.ChartL1) },
                { name: 'L2N', data: @Html.Raw(ViewBag.ChartL2) },
                { name: 'L3N', data: @Html.Raw(ViewBag.ChartL3) }
            ],
            chart: { type: 'line', height: 380, background: '#1E293B', toolbar: { show: true }, zoom: { enabled: true } },
            colors: ['#2563EB', '#10B981', '#F59E0B'],
            stroke: { curve: 'straight', width: 1.5 },
            xaxis: { categories: @Html.Raw(ViewBag.ChartLabels), labels: { style: { colors: '#94A3B8', fontSize: '9px' }, rotate: -45 }, tickAmount: 12 },
            yaxis: { labels: { style: { colors: '#94A3B8' } } },
            annotations: {
                yaxis: [
                    { y: @ViewBag.UpperBound, borderColor: '#EF4444', strokeDashArray: 4, label: { text: 'Upper bound', style: { color: '#FFF', background: '#EF4444', fontSize: '10px' } } },
                    { y: @ViewBag.LowerBound, borderColor: '#EF4444', strokeDashArray: 4, label: { text: 'Lower bound', style: { color: '#FFF', background: '#EF4444', fontSize: '10px' } } }
                ]
            },
            tooltip: { theme: 'dark', y: { formatter: function(v) { return v.toFixed(1) + ' V'; } } },
            grid: { borderColor: '#334155' },
            markers: { size: 0 }
        }).render();
    </script>
}
