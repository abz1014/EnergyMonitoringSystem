@{
    ViewData["Title"] = "Executive QBR";
    var hasData = (bool)(ViewBag.HasData ?? false);
    var currency = ViewBag.Currency as string ?? "Rs.";
    var monthly = ViewBag.Monthly as IEnumerable<dynamic>;
}

<div style="background-color: #0F172A; color: #E2E8F0; min-height: 100vh; padding: 20px;" id="qbrContent">
    <div class="mb-4 d-flex justify-content-between align-items-start no-print">
        <div>
            <h1 class="h2 mb-2">Executive Quarterly Business Review</h1>
            <p class="text-muted">Auto-generated summary of energy performance, cost, and savings opportunities</p>
            <div style="font-size: 13px;">
                <span style="color: #64748B;">Related financial views:</span>
                <a asp-controller="CostDashboard" asp-action="Index" style="color: #2563EB; text-decoration: none; margin-left: 8px;">Cost Dashboard &rarr;</a>
                <a asp-controller="Budget" asp-action="Index" style="color: #2563EB; text-decoration: none; margin-left: 12px;">Budget vs Actual &rarr;</a>
            </div>
        </div>
        @if (hasData)
        {
            <button onclick="window.print()" class="btn btn-outline-light btn-sm">Print / Save as PDF</button>
        }
    </div>

    <form method="get" class="mb-4 p-3 no-print" style="background-color: #1E293B; border-radius: 8px;">
        <div class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label text-light" style="font-size:12px;">Quarter</label>
                <select name="quarter" class="form-select form-select-sm" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;">
                    @for (int q = 1; q <= 4; q++)
                    {
                        if (q == (int)ViewBag.Quarter) { <option value="@q" selected>Q@(q)</option> } else { <option value="@q">Q@(q)</option> }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-light" style="font-size:12px;">Year</label>
                <select name="year" class="form-select form-select-sm" style="background-color: #0F172A; color: #E2E8F0; border-color: #334155;">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 2; y--)
                    {
                        if (y == (int)ViewBag.Year) { <option value="@y" selected>@y</option> } else { <option value="@y">@y</option> }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100" style="background-color: #2563EB;">Generate</button>
            </div>
        </div>
    </form>

    <div class="mb-4 text-center">
        <h2 style="color: #FFFFFF;">@ViewBag.CompanyName</h2>
        <h4 style="color: #3B82F6;">@ViewBag.QuarterLabel Energy Performance Review</h4>
        <p style="color: #64748B; font-size: 13px;">Period: @ViewBag.PeriodLabel | Generated: @(((DateTime)ViewBag.GeneratedAt).ToString("MMM dd, yyyy HH:mm"))</p>
    </div>

    @if (hasData)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="p-4 text-center" style="background-color: #1E293B; border-radius: 8px;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Total Consumption</div>
                    <div style="color: #FFFFFF; font-size: 24px; font-weight: 700;">@ViewBag.TotalKwh <span style="font-size:11px;color:#64748B;">kWh</span></div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-4 text-center" style="background-color: #1E293B; border-radius: 8px;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Total Cost</div>
                    <div style="color: #F59E0B; font-size: 24px; font-weight: 700;">@currency @(((double)ViewBag.TotalCost).ToString("N0"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-4 text-center" style="background-color: #1E293B; border-radius: 8px;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Peak Demand</div>
                    <div style="color: #FFFFFF; font-size: 24px; font-weight: 700;">@ViewBag.PeakKw <span style="font-size:11px;color:#64748B;">kW</span></div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-4 text-center" style="background-color: #1E293B; border-radius: 8px;">
                    <div style="color: #94A3B8; font-size: 11px; text-transform: uppercase;">Average Power Factor</div>
                    <div style="color: #FFFFFF; font-size: 24px; font-weight: 700;">@ViewBag.AvgPf</div>
                </div>
            </div>
        </div>

        <div class="p-4 mb-4" style="background-color: #1E293B; border-radius: 8px;">
            <h5 class="text-light mb-3">Monthly Trend</h5>
            <div id="monthlyChart" style="height: 300px;"></div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px; height: 100%;">
                    <h5 class="text-light mb-3">Savings Opportunities Identified</h5>
                    @{ var totalSavings = (double)ViewBag.TotalSavingsOpportunity; }
                    @if (totalSavings > 0)
                    {
                        @if ((double)ViewBag.PfPenalty > 0)
                        {
                            <div class="d-flex justify-content-between mb-2"><span style="color:#94A3B8;">Power Factor Penalty</span><span style="color:#EF4444;">@currency @(((double)ViewBag.PfPenalty).ToString("N0"))</span></div>
                        }
                        @if ((double)ViewBag.WeekendWasteCost > 0)
                        {
                            <div class="d-flex justify-content-between mb-2"><span style="color:#94A3B8;">Weekend/Off-Hours Waste</span><span style="color:#EF4444;">@currency @(((double)ViewBag.WeekendWasteCost).ToString("N0"))</span></div>
                        }
                        <hr style="border-color:#334155;" />
                        <div class="d-flex justify-content-between"><strong style="color:#E2E8F0;">Total Opportunity</strong><strong style="color:#EF4444;">@currency @totalSavings.ToString("N0")</strong></div>
                    }
                    else
                    {
                        <p style="color: #10B981;">No significant savings opportunities identified this quarter — operations are running efficiently.</p>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-4" style="background-color: #1E293B; border-radius: 8px; height: 100%;">
                    <h5 class="text-light mb-3">Reliability & Alarms</h5>
                    <div class="d-flex justify-content-between mb-2"><span style="color:#94A3B8;">Total Alarms Raised</span><span style="color:#E2E8F0;">@ViewBag.AlarmCount</span></div>
                    <div class="d-flex justify-content-between mb-2"><span style="color:#94A3B8;">Critical Alarms</span><span style="color:@((int)ViewBag.CriticalAlarmCount > 0 ? "#EF4444" : "#10B981");">@ViewBag.CriticalAlarmCount</span></div>
                    <div class="d-flex justify-content-between"><span style="color:#94A3B8;">Data Points Recorded</span><span style="color:#E2E8F0;">@(((int)ViewBag.RecordCount).ToString("N0"))</span></div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="state-card state-empty">
            <div style="font-size: 48px; color: #64748B;">&#128203;</div>
            <h4 style="color: #E2E8F0;">No data available for @ViewBag.QuarterLabel</h4>
        </div>
    }
</div>

<style>
    @@media print {
        .no-print, .sidebar, .topbar, .footer { display: none !important; }
        .main-content { margin: 0 !important; }
        body { background: white !important; }
    }
</style>

@if (hasData)
{
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@latest/dist/apexcharts.min.js"></script>
    <script>
        var monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthly));
        new ApexCharts(document.querySelector('#monthlyChart'), {
            series: [{ name: 'Consumption (kWh)', data: monthlyData.map(function(m) { return m.Kwh; }) }],
            chart: { type: 'bar', height: 300, background: '#1E293B', toolbar: { show: true } },
            plotOptions: { bar: { borderRadius: 4, columnWidth: '40%' } },
            colors: ['#2563EB'],
            xaxis: { categories: monthlyData.map(function(m) { return m.Month; }), labels: { style: { colors: '#94A3B8' } } },
            yaxis: { labels: { style: { colors: '#94A3B8' } } },
            tooltip: { theme: 'dark' },
            grid: { borderColor: '#334155' }
        }).render();
    </script>
}
